# more Code headless server configuration.
#
# Bind to a trusted private-network address (or 0.0.0.0) only after reviewing
# the security guidance in the headless Linux documentation.
MORECODE_T3CODE_HOST=127.0.0.1
MORECODE_T3CODE_PORT=3773
MORECODE_T3CODE_MODE=web
MORECODE_T3CODE_HOME=/var/lib/morecode/state
MORECODE_T3CODE_NO_BROWSER=true

