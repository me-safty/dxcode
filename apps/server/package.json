{
  "name": "t3",
  "version": "0.0.24",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pingdotgg/t3code",
    "directory": "apps/server"
  },
  "bin": {
    "t3": "./dist/bin.mjs",
    "t3work": "./dist/t3work-bin.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "node scripts/t3work-dev-entry.mjs",
    "dev:t3work": "node --watch src/t3work-bin.ts",
    "build": "node scripts/cli.ts build",
    "build:bundle": "tsdown",
    "start": "node dist/bin.mjs",
    "start:t3work": "node dist/t3work-bin.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.111",
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/platform-node-shared": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@opencode-ai/sdk": "^1.3.15",
    "@pierre/diffs": "catalog:",
    "@t3tools/integrations-atlassian": "workspace:*",
    "@t3tools/integrations-core": "workspace:*",
    "@t3tools/project-context": "workspace:*",
    "@t3tools/t3work-skill-packs": "workspace:*",
    "effect": "catalog:",
    "node-pty": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@t3tools/contracts": "workspace:*",
    "@t3tools/shared": "workspace:*",
    "@t3tools/tailscale": "workspace:*",
    "@t3tools/web": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "effect-acp": "workspace:*",
    "effect-codex-app-server": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^22.16 || ^23.11 || >=24.10"
  }
}
