+async function highlightPatchLinesInChunks(input: {
+  readonly lines: ReadonlyArray<string>;
+  readonly language: string;
+  readonly theme: string;
+  readonly onChunk: (
+    startIndex: number,
+    tokens: ReadonlyArray<ReadonlyArray<ReviewHighlightedToken>>,
+  ) => void;
