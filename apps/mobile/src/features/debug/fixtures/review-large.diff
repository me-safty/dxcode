+
+function normalizeTokens(
+  tokenLines: ReadonlyArray<ReadonlyArray<{ content: string; color?: string; fontStyle?: number }>>,
+): ReadonlyArray<ReadonlyArray<DebugToken>> {
+  return tokenLines.map((line) =>
