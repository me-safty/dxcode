+      content: token.content,
+      color: token.color ?? null,
+      fontStyle: token.fontStyle ?? null,
+    })),
+  );
+}
+
+function makeDebugCodeLine(index: number): string {
+  const label = `generatedLine${String(index).padStart(5, "0")}`;
+  switch (index % 8) {
+    case 0:
+      return `export async function ${label}(input: { value: number; name: string }) {`;
+    case 1:
+      return `  const normalized = input.name.trim().toLowerCase();`;
+    case 2:
+      return `  const result = await Promise.resolve({ id: "${label}", score: input.value * ${index + 1} });`;
+    case 3:
+      return `  if (result.score > ${index * 17}) return normalized + ":" + result.id;`;
+    case 4:
+      return `  return [normalized, String(result.score), "${"x".repeat((index % 24) + 8)}"].join("/");`;
+    case 5:
+      return `}`;
+    case 6:
+      return `type ${label}Record = Readonly<{ id: string; createdAt: Date; tags: string[] }>;`;
+    default:
