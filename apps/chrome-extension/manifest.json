{
  "manifest_version": 3,
  "name": "T3 Code Browser Transfer",
  "description": "Links T3 Code browser chats with matching dev server tabs for annotations.",
  "version": "0.0.1",
  "permissions": ["storage", "tabs", "windows", "sidePanel", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["transfer-content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidepanel.html", "sidepanel.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src http: https:;"
  },
  "action": {
    "default_title": "T3 Code Browser Transfer"
  }
}
