T3WORK_ATLASSIAN_CLIENT_ID=your-atlassian-oauth-client-id
T3WORK_ATLASSIAN_CLIENT_SECRET=your-atlassian-oauth-client-secret
VITE_ATLASSIAN_CLIENT_ID=your-atlassian-oauth-client-id

# Optional: override the OAuth redirect URI when the app shell uses a custom protocol
# (desktop Electron uses t3code-dev://app, which Atlassian cannot register).
# Default for desktop dev: VITE_DEV_SERVER_URL + /oauth/callback (set by dev:desktop).
# Default for browser dev: window.location.origin + /oauth/callback.
# VITE_ATLASSIAN_OAUTH_REDIRECT_URI=http://127.0.0.1:5733/oauth/callback

# Optional: default Jira Cloud site for basic-auth connect and multi-site account pickers.
# Example: https://your-company.atlassian.net
T3WORK_ATLASSIAN_SITE_URL=https://your-company.atlassian.net

# Register these callback URLs in the Atlassian Developer Console OAuth app:
#   http://localhost:5733/oauth/callback   (browser dev via vp dev / dev:web)
#   http://127.0.0.1:5733/oauth/callback   (desktop dev via dev:desktop)
# Add both if teammates use browser and desktop dev. Match the port you run on.
