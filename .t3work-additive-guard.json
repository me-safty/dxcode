{
  "guardFileRule": "DO NOT EDIT THIS FILE MANUALLY. Update allowlists via controlled migration changes only.",
  "baseRef": "upstream/main",
  "requiredPrefixes": ["t3work-", "t3work."],
  "locWarnThreshold": 150,
  "locFailThreshold": 1800,
  "allowedModifiedFiles": [
    "AGENTS.md",
    "package.json",
    "bun.lock",
    "apps/server/package.json",
    "apps/server/src/server.ts",
    "apps/server/tsdown.config.ts",
    "apps/web/package.json",
    "apps/web/vite.config.ts",
    "apps/web/src/routes/__root.tsx",
    "apps/web/src/routeTree.gen.ts",
    "packages/t3-adapter/src/workspace.ts"
  ],
  "allowedUnprefixedNewFiles": [
    ".t3work-additive-guard.json",
    ".claude/**",
    "docs/t3work-mvp/**",
    "docs/t3work-additive-whitelist.md",
    "docs/t3work-company-agentic-shell-handoff.md",
    "apps/web/src/routes/t3work.tsx",
    "apps/web/src/types/*.d.ts",
    "packages/integrations-atlassian/**",
    "packages/integrations-core/**",
    "packages/project-context/**",
    "packages/project-recipes/**",
    "packages/t3-adapter/**",
    "t3work-additive-guard.mjs"
  ]
}
