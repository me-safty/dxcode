# Machine ops — copy to .env.machine and fill in your values.
# See .agents/skills/affil-machine-ops/SKILL.md for usage.
MACHINE_SSH_HOST=
MACHINE_SSH_USER=ubuntu
MACHINE_SSH_KEY=
MACHINE_PUBLIC_HOSTNAME=
MACHINE_T3_REPO_PATH=/home/ubuntu/t3code
MACHINE_T3_PORT=3773
MACHINE_T3_SERVICE=t3code
MACHINE_T3CODE_HOME=/var/lib/t3code
MACHINE_WORKSPACE_ROOT=/srv/t3-workspaces
MACHINE_ENV_FILE=/etc/t3code.env
MACHINE_CADDY_CONFIG=/etc/caddy/Caddyfile
CONVEX_SITE_URL=
