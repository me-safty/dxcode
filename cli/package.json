{
  "name": "@t3tools/cli",
  "version": "0.0.1",
  "description": "T3 Code CLI - AI pair programmer powered by Claude",
  "license": "MIT",
  "type": "module",
  "bin": {
    "t3code": "./dist/index.js",
    "t3c": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pingdotgg/t3code",
    "directory": "cli"
  },
  "homepage": "https://github.com/pingdotgg/t3code#readme",
  "bugs": {
    "url": "https://github.com/pingdotgg/t3code/issues"
  },
  "scripts": {
    "dev": "tsup src/index.ts --format esm --watch",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepublishOnly": "bun run build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "diff": "^7.0.0",
    "ink": "^5.1.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "catalog:",
    "@types/react": "^18.3.1",
    "tsup": "^8.4.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": "^22.16 || >=24.10"
  },
  "keywords": [
    "t3code",
    "claude",
    "ai",
    "coding",
    "assistant",
    "cli",
    "anthropic"
  ]
}
