# Atlas Vector compose configuration (docker-compose.atlas.yml).
# Copy to .env.atlas and adjust as needed:  cp .env.atlas.example .env.atlas
#
# Browser-facing base URL of Vector's FastAPI (published on the host). It is
# baked into the web build, so it must be reachable from the BROWSER (host),
# not from inside the compose network.
VITE_ATLAS_API_URL=http://localhost:8000
