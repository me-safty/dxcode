{
  "version": 1,
  "defaultEffect": "allow",
  "rules": [
    {
      "id": "protect-repository-core",
      "effect": "require_approval",
      "when": {
        "paths": ["apps/**", "packages/**"],
        "risk": "high"
      },
      "reason": "High-risk changes to core monorepo typescript react-native paths require approval."
    },
    {
      "id": "protect-repository-config",
      "effect": "require_approval",
      "when": {
        "paths": [
          ".devcontainer/**",
          ".github/workflows/**",
          "infra/**",
          "package.json",
          "pnpm-lock.yaml",
          "pnpm-workspace.yaml"
        ],
        "risk": "high"
      },
      "reason": "High-risk changes to repository automation and build configuration require approval."
    },
    {
      "id": "block-secrets",
      "effect": "deny",
      "when": {
        "paths": ["**/.env*", "**/*.pem", "**/*.key", "**/*secret*"]
      },
      "reason": "Secret-like files are blocked by policy."
    }
  ]
}
